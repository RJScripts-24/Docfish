{
	"name": "docfish-backend",
	"version": "1.0.0",
	"private": true,
	"description": "Docfish invoice extraction backend",
	"main": "dist/index.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/src/index.js",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.7.1",
		"morgan": "^1.10.0",
		"multer": "^1.4.5-lts.1",
		"openai": "^4.68.0",
		"pdf-parse": "^1.1.1"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/morgan": "^1.9.9",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.7.7",
		"@types/pdf-parse": "^1.1.4",
		"@types/supertest": "^6.0.2",
		"@typescript-eslint/eslint-plugin": "^8.12.2",
		"@typescript-eslint/parser": "^8.12.2",
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.6.3"
	}
}
