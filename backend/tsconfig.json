{
	"compilerOptions": {
		"target": "ES2021",
		"module": "Node16",
		"moduleResolution": "Node16",
		"rootDir": ".",
		"outDir": "dist",
		"esModuleInterop": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"strict": false,
		"types": ["node", "jest"]
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
